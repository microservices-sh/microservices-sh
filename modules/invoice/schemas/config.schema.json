{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Invoice Module Config",
  "type": "object",
  "properties": {
    "defaultSeries": { "type": "string", "default": "INV" },
    "defaultCurrency": { "type": "string", "minLength": 3, "maxLength": 3, "default": "USD" },
    "defaultTermsDays": { "type": "integer", "minimum": 0, "maximum": 365, "default": 14 },
    "numberPadWidth": { "type": "integer", "minimum": 0, "maximum": 12, "default": 5 },
    "defaultListLimit": { "type": "integer", "minimum": 1, "maximum": 500, "default": 100 }
  },
  "additionalProperties": false
}

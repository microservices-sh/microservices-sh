{
  "name": "@microservices-sh/payment",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Prebuilt microservices.sh payment module: Stripe-backed payment intents, payment records, and signed webhook verification.",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./schemas": "./src/schemas.ts",
    "./hooks": "./src/hooks.ts",
    "./manifest": "./src/manifest/index.ts",
    "./config": "./src/config/index.ts",
    "./schema": "./src/schema/index.ts",
    "./events": "./src/events/index.ts",
    "./permissions": "./src/permissions/index.ts",
    "./resources": "./src/resources/index.ts",
    "./service": "./src/service/index.ts",
    "./ports": "./src/ports/index.ts",
    "./rpc": "./src/rpc.ts",
    "./webhook": "./src/webhook.ts",
    "./adapters/d1": "./src/adapters/d1-payment-repository.ts",
    "./adapters/memory": "./src/adapters/memory-payment-repository.ts",
    "./adapters/stripe-gateway": "./src/adapters/stripe-payment-gateway.ts",
    "./adapters/memory-gateway": "./src/adapters/memory-payment-gateway.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "check:spec": "node ../../packages/workspace-tools/src/index.js check module --path ."
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "typescript": "^5.9.3"
  }
}

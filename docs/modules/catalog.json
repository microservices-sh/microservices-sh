      "id": "auth",
      "name": "Auth",
      "version": "0.1.0",
      "status": "available",
      "class": "platform",
      "mount": "/auth",
      "docPath": "docs/modules/auth.md",
      "summary": "EdDSA service-token mint/verify, scope checks, and JWKS for auth-gated inter-service communication.",
      "requires": [],
      "permissions": [
        "auth.mint",
        "auth.verify",
        "auth.admin"
      ],
      "rpc": [
        {
          "method": "mintToken",
          "scope": "auth.mint",
          "public": false
        },
        {
          "method": "verifyToken",
          "scope": "auth.verify",
          "public": false
        },
        {
          "method": "getJwks",
          "scope": null,
          "public": true
        }
      ],
      "approvalRisk": "high",
      "secrets": [
        "AUTH_SIGNING_KEY"
      ],
      "resources": [
        "D1"
      ],
      "hooks": [
        "beforeMintToken",
        "afterTokenMinted"
      ],
      "events": [
        "auth.token_minted",
        "auth.key_rotated"
      ]
    },

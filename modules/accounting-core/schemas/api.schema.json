{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Accounting Core API",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "accountTypes": {
      "type": "array",
      "items": {
        "enum": ["asset", "liability", "equity", "revenue", "expense"]
      }
    },
    "chartOfAccountsStandards": {
      "type": "array",
      "items": {
        "enum": ["gaap", "ifrs"]
      }
    },
    "journalEntryStatuses": {
      "type": "array",
      "items": {
        "enum": ["draft", "posted", "void"]
      }
    },
    "fiscalPeriodStatuses": {
      "type": "array",
      "items": {
        "enum": ["open", "closed", "locked"]
      }
    },
    "fiscalPeriodTypes": {
      "type": "array",
      "items": {
        "enum": ["month", "quarter", "year", "custom"]
      }
    },
    "generalLedgerFields": {
      "type": "array",
      "items": {
        "enum": ["openingBalanceCents", "runningBalanceCents", "closingBalanceCents"]
      }
    },
    "accountingSettingsFields": {
      "type": "array",
      "items": {
        "enum": [
          "accountingStandard",
          "baseCurrency",
          "fiscalYearStartMonth",
          "defaultArAccountId",
          "defaultApAccountId",
          "defaultIncomeAccountId",
          "defaultDepositAccountId",
          "stripeDepositAccountId"
        ]
      }
    }
  }
}

{
  "name": "@microservices-sh/webhook-delivery",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Prebuilt microservices.sh webhook-delivery module: outbound HMAC-signed event delivery to external endpoints with delivery logging.",
  "exports": {
    ".": "./src/index.ts",
    "./preview": "./reference-ui/Preview.svelte",
    "./types": "./src/types.ts",
    "./schemas": "./src/schemas.ts",
    "./hooks": "./src/hooks.ts",
    "./manifest": "./src/manifest/index.ts",
    "./config": "./src/config/index.ts",
    "./schema": "./src/schema/index.ts",
    "./events": "./src/events/index.ts",
    "./permissions": "./src/permissions/index.ts",
    "./resources": "./src/resources/index.ts",
    "./service": "./src/service/index.ts",
    "./ports": "./src/ports/index.ts",
    "./signing": "./src/signing.ts",
    "./adapters/d1": "./src/adapters/d1-endpoint-store.ts",
    "./adapters/memory": "./src/adapters/memory-endpoint-store.ts",
    "./adapters/d1-delivery-log": "./src/adapters/d1-delivery-log.ts",
    "./adapters/memory-delivery-log": "./src/adapters/memory-delivery-log.ts",
    "./adapters/fetch-http": "./src/adapters/fetch-http-client.ts",
    "./adapters/memory-http": "./src/adapters/memory-http-client.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "check:spec": "node ../../packages/workspace-tools/src/index.js check module --path .",
    "test": "vitest run --root ../.. modules/webhook-delivery/tests/connections.test.ts"
  },
  "dependencies": {
    "@microservices-sh/connection-contract": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "@microservices-sh/ui": "workspace:*",
    "svelte": "^5.0.0",
    "typescript": "^5.9.3"
  }
}

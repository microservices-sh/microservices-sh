{
  "name": "create-microservices-app",
  "version": "0.4.1",
  "description": "Scaffold a Cloudflare-native SaaS app in one command — Workers, D1, SvelteKit or Hono, with verified auth, booking, payment & email modules.",
  "type": "module",
  "homepage": "https://microservices.sh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/microservices-sh/microservices-sh.git",
    "directory": "packages/create-microservices-app"
  },
  "bugs": "https://github.com/microservices-sh/microservices-sh/issues",
  "bin": {
    "create-microservices-app": "dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "frameworks.json",
    "shim",
    "README.md"
  ],
  "scripts": {
    "start": "pnpm run build && node dist/index.js",
    "build": "node scripts/build.js && node --check dist/index.js",
    "gen:template-types": "node scripts/gen-template-types.mjs",
    "smoke": "node scripts/smoke-test.js",
    "test": "node --test \"tests/*.test.mjs\""
  },
  "devDependencies": {
    "esbuild": "0.27.7",
    "json-schema-to-typescript": "15.0.4"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "cloudflare",
    "cloudflare-workers",
    "workers",
    "d1",
    "hono",
    "sveltekit",
    "saas",
    "saas-starter",
    "boilerplate",
    "scaffold",
    "fullstack",
    "edge",
    "microservices",
    "create-app"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}

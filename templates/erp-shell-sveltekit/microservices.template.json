{
  "schemaVersion": "2026-06-13",
  "id": "erp-shell-sveltekit",
  "version": "0.1.0",
  "status": "ready",
  "displayName": "ERP Shell SvelteKit",
  "category": "business-system",
  "summary": "Single-company ERP shell for Cloudflare SvelteKit: one organization, employees + roles via RBAC, and operational modules (customers, invoices, files) that plug into a lock-driven left sidebar.",
  "runtime": {
    "language": "typescript",
    "framework": "sveltekit",
    "adapter": "@sveltejs/adapter-cloudflare",
    "platform": "cloudflare-workers",
    "entrypoint": ".svelte-kit/cloudflare/_worker.js"
  },
  "deployment": {
    "defaultMode": "managed-cloudflare",
    "managedNamespace": "microservices-sh",
    "byoCloudflare": "later"
  },
  "modules": {
    "required": [
      "auth",
      "org-team-rbac",
      "admin-shell",
      "audit-log",
      "customer",
      "invoice",
      "file-media"
    ],
    "optional": [
      "identity",
      "jobs-workflows",
      "notifications-inapp",
      "email",
      "webhook-delivery"
    ]
  },
  "slots": {
    "identity": {
      "activeModule": "auth",
      "allowedModules": [
        "auth",
        "identity"
      ],
      "approvalRisk": "high"
    },
    "tenancy": {
      "activeModule": "org-team-rbac",
      "allowedModules": [
        "org-team-rbac"
      ],
      "approvalRisk": "high"
    },
    "admin": {
      "activeModule": "admin-shell",
      "allowedModules": [
        "admin-shell"
      ],
      "approvalRisk": "medium"
    },
    "audit": {
      "activeModule": "audit-log",
      "allowedModules": [
        "audit-log"
      ],
      "approvalRisk": "medium"
    },
    "crm": {
      "activeModule": "customer",
      "allowedModules": [
        "customer"
      ],
      "approvalRisk": "medium"
    },
    "invoicing": {
      "activeModule": "invoice",
      "allowedModules": [
        "invoice"
      ],
      "approvalRisk": "medium"
    },
    "files": {
      "activeModule": "file-media",
      "allowedModules": [
        "file-media"
      ],
      "approvalRisk": "medium"
    },
    "accounts": {
      "activeModule": "identity",
      "allowedModules": [
        "identity"
      ],
      "approvalRisk": "high"
    },
    "jobs": {
      "activeModule": "jobs-workflows",
      "allowedModules": [
        "jobs-workflows"
      ],
      "approvalRisk": "low"
    },
    "notifications": {
      "activeModule": "notifications-inapp",
      "allowedModules": [
        "notifications-inapp"
      ],
      "approvalRisk": "low"
    },
    "messaging": {
      "activeModule": null,
      "allowedModules": [
        "email"
      ],
      "approvalRisk": "high"
    }
  },
  "sourcePolicy": {
    "templateOwns": [
      "app shell",
      "routes",
      "layout",
      "lock-driven sidebar nav",
      "UI overlays",
      "composition glue"
    ],
    "modulesOwn": [
      "domain behavior",
      "schemas",
      "use cases",
      "ports",
      "migrations"
    ],
    "apiLogic": "detached-use-cases-with-sveltekit-adapters"
  },
  "checks": [
    { "id": "migrations", "file": "migrations/0001_core.sql" },
    { "id": "http-smoke", "file": "scripts/smoke-http.mjs" }
  ]
}

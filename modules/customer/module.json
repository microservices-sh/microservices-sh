{
  "schemaVersion": "2026-06-13",
  "id": "customer",
  "name": "Customer",
  "version": "0.1.0",
  "status": "available",
  "class": "core",
  "summary": "Customer profiles, contact fields, notes, lifecycle events, and customer admin data access.",
  "runtime": {
    "language": "typescript",
    "platform": "cloudflare-workers",
    "frameworkNeutral": true,
    "routeAdapters": ["sveltekit", "hono-later"]
  },
  "entrypoint": "src/index.ts",
  "resources": [
    { "type": "d1", "binding": "DB", "tables": ["customers", "domain_events"] }
  ],
  "permissions": ["customer.read", "customer.write", "customer.admin", "customer.extend", "customer.observe"],
  "connections": {
    "requires": [],
    "optional": ["auth", "audit-log", "email"],
    "rpc": {
      "exposes": [
        { "method": "getCustomer", "scope": "customer.read", "public": false },
        { "method": "listCustomers", "scope": "customer.read", "public": false },
        { "method": "upsertCustomer", "scope": "customer.write", "public": false }
      ],
      "calls": []
    },
    "events": {
      "emits": ["customer.created", "customer.updated"],
      "consumes": []
    },
    "hookPoints": {
      "beforeCustomerCreate": { "kind": "filter", "scope": "customer.extend" },
      "afterCustomerUpdated": { "kind": "observer", "scope": "customer.observe" }
    },
    "provides": { "hooks": [] }
  },
  "customization": {
    "default": "config-hooks",
    "supported": ["config", "hooks", "overlay", "fork"]
  },
  "surfaces": {
    "admin": {
      "applicable": true,
      "nav": [{ "label": "Customers", "path": "/customers", "permission": "customer.read", "icon": "Users" }],
      "referenceUi": ["reference-ui/README.md"]
    },
    "visitor": {
      "applicable": true,
      "featureKey": "memberProfile",
      "referenceUi": ["reference-ui/README.md"]
    },
    "agentic": {
      "applicable": true,
      "tools": ["customer.listCustomers", "customer.getCustomer", "customer.upsertCustomer"],
      "skillPaths": ["skills/customer-operator/SKILL.md"],
      "approvalRequiredFor": ["customer.upsertCustomer", "customer.deleteCustomer"]
    }
  },
  "skills": [
    {
      "id": "customer-operator",
      "path": "skills/customer-operator/SKILL.md",
      "recommendedFor": ["admin-operations", "customer-lifecycle", "visitor-support"]
    }
  ],
  "approval": {
    "risk": "medium",
    "requiresApprovalFor": ["migrations", "pii-fields", "production-deploy", "external-sync"]
  }
}

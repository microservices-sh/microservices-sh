{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Knowledge Base RAG Config",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "defaultSearchLimit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50,
      "default": 8
    },
    "maxSearchLimit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 20
    },
    "minAnswerCitations": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "default": 1
    }
  }
}

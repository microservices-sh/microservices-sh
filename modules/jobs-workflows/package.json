{
  "name": "@microservices-sh/jobs-workflows",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Prebuilt microservices.sh jobs-workflows module: durable background jobs with idempotent execution, backoff retries, dead-letter handling, and catch-up scheduling.",
  "exports": {
    ".": "./src/index.ts",
    "./preview": "./reference-ui/Preview.svelte",
    "./types": "./src/types.ts",
    "./schemas": "./src/schemas.ts",
    "./hooks": "./src/hooks.ts",
    "./manifest": "./src/manifest/index.ts",
    "./config": "./src/config/index.ts",
    "./schema": "./src/schema/index.ts",
    "./events": "./src/events/index.ts",
    "./permissions": "./src/permissions/index.ts",
    "./resources": "./src/resources/index.ts",
    "./service": "./src/service/index.ts",
    "./ports": "./src/ports/index.ts",
    "./backoff": "./src/backoff.ts",
    "./adapters/d1": "./src/adapters/d1-job-store.ts",
    "./adapters/memory": "./src/adapters/memory-job-store.ts",
    "./adapters/cf-queue": "./src/adapters/cf-queue-producer.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "check:spec": "node ../../packages/workspace-tools/src/index.js check module --path .",
    "test": "vitest run --root ../.. modules/jobs-workflows/src/jobs-workflows.test.ts modules/jobs-workflows/tests/connections.test.ts"
  },
  "dependencies": {
    "@microservices-sh/connection-contract": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "@microservices-sh/ui": "workspace:*",
    "svelte": "^5.0.0",
    "typescript": "^5.9.3"
  }

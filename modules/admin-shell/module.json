{
  "schemaVersion": "2026-06-13",
  "id": "admin-shell",
  "name": "Admin Shell",
  "version": "0.1.0",
  "status": "available",
  "class": "platform",
  "summary": "Schema-driven admin CRUD over your existing D1 tables: a resource registry plus generic list/get/create/update/delete with RBAC, soft-delete, search/pagination, and audit hooks. UI is host-rendered.",
  "runtime": {
    "language": "typescript",
    "platform": "cloudflare-workers",
    "frameworkNeutral": true,
    "routeAdapters": ["sveltekit", "hono-later"]
  },
  "entrypoint": "src/index.ts",
  "resources": [],
  "permissions": ["admin.access", "admin.read", "admin.write", "admin-shell.extend"],
  "connections": {
    "requires": [],
    "optional": ["auth", "audit-log"],
    "rpc": { "exposes": [], "calls": [] },
    "events": {
      "emits": ["admin.record_created", "admin.record_updated", "admin.record_deleted"],
      "consumes": []
    },
    "hookPoints": {
      "beforeWrite": { "kind": "filter", "scope": "admin-shell.extend" },
      "onAdminAction": { "kind": "observer", "scope": "admin-shell.extend" }
    },
    "provides": { "hooks": [] }
  },
  "customization": {
    "default": "config-hooks",
    "supported": ["config", "hooks", "overlay", "fork"]
  },
  "surfaces": {
    "admin": {
      "applicable": true,
      "nav": [{ "label": "Admin", "path": "/admin", "permission": "admin.access", "icon": "Settings" }],
      "referenceUi": ["reference-ui/README.md"]
    },
    "visitor": {
      "applicable": false
    },
    "agentic": {
      "applicable": true,
      "tools": ["admin-shell.listRecords", "admin-shell.getRecord", "admin-shell.createRecord", "admin-shell.updateRecord", "admin-shell.deleteRecord"],
      "skillPaths": ["skills/admin-shell-operator/SKILL.md"],
      "approvalRequiredFor": ["admin-shell.createRecord", "admin-shell.updateRecord", "admin-shell.deleteRecord"]
    }
  },
  "skills": [
    {
      "id": "admin-shell-operator",
      "path": "skills/admin-shell-operator/SKILL.md",
      "recommendedFor": ["admin-operations", "resource-management", "agentic-admin"]
    }
  ],
  "approval": {
    "risk": "high",
    "requiresApprovalFor": ["data-mutations", "permission-changes", "production-deploy"]
  }
}

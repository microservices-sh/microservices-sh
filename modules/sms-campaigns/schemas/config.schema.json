{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SMS Campaigns Config",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "defaultVendor": {
      "type": "string",
      "enum": ["clicksend", "twilio", "sns", "memory"]
    },
    "maxBatchSize": {
      "type": "integer",
      "minimum": 1
    }
  }
}

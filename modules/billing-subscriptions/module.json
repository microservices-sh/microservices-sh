{
  "schemaVersion": "2026-06-13",
  "id": "billing-subscriptions",
  "name": "Billing & Subscriptions",
  "version": "0.1.0",
  "status": "available",
  "class": "provider",
  "summary": "Recurring plans and subscription state on top of Stripe: a complete status state machine, idempotent webhook application, plan changes, metered usage, and dunning hooks.",
  "runtime": {
    "language": "typescript",
    "platform": "cloudflare-workers",
    "frameworkNeutral": true,
    "routeAdapters": ["sveltekit", "hono-later"]
  },
  "entrypoint": "src/index.ts",
  "resources": [
    { "type": "d1", "binding": "DB", "tables": ["plans", "subscriptions", "billing_events", "usage_records"] }
  ],
  "permissions": ["billing.read", "billing.write", "billing.admin", "billing-subscriptions.extend", "billing-subscriptions.observe"],
  "connections": {
    "requires": [],
    "optional": ["payment", "org-team-rbac", "jobs-workflows", "audit-log"],
    "rpc": {
      "exposes": [
        { "method": "startSubscription", "scope": "billing.write", "public": false },
        { "method": "applyStripeEvent", "scope": "billing.write", "public": false }
      ],
      "calls": []
    },
    "events": {
      "emits": ["subscription.started", "subscription.activated", "subscription.past_due", "subscription.canceled", "subscription.plan_changed"],
      "consumes": []
    },
    "hookPoints": {
      "beforeSubscriptionChange": { "kind": "guard", "scope": "billing-subscriptions.extend" },
      "onSubscriptionActivated": { "kind": "observer", "scope": "billing-subscriptions.observe" },
      "onSubscriptionPastDue": { "kind": "observer", "scope": "billing-subscriptions.observe" }
    },
    "provides": { "hooks": [] }
  },
  "customization": {
    "default": "config-hooks",
    "supported": ["config", "hooks", "overlay", "fork"]
  },
  "surfaces": {
    "admin": {
      "applicable": true,
      "nav": [{ "label": "Billing", "path": "/settings/billing", "permission": "billing.read", "icon": "Receipt" }],
      "referenceUi": ["reference-ui/README.md"]
    },
    "visitor": {
      "applicable": false
    },
    "agentic": {
      "applicable": true,
      "tools": ["billing-subscriptions.listPlans", "billing-subscriptions.startSubscription", "billing-subscriptions.changePlan", "billing-subscriptions.cancelSubscription"],
      "skillPaths": ["skills/billing-subscriptions-operator/SKILL.md"],
      "approvalRequiredFor": ["billing-subscriptions.startSubscription", "billing-subscriptions.changePlan", "billing-subscriptions.cancelSubscription"]
    }
  },
  "skills": [
    {
      "id": "billing-subscriptions-operator",
      "path": "skills/billing-subscriptions-operator/SKILL.md",
      "recommendedFor": ["admin-operations", "subscription-management", "money-mutations"]
    }
  ],
  "approval": {
    "risk": "high",
    "requiresApprovalFor": ["migrations", "money-mutations", "production-deploy"]
  }
}

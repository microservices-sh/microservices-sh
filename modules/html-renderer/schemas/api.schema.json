{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HTML Renderer API",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "html": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "ttlSeconds": {
      "type": "integer",
      "minimum": 0
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}

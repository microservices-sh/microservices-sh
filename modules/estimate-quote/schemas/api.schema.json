{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Estimate Quote API",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "quoteNumber": {
      "type": "string"
    },
    "clientId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "sent",
        "viewed",
        "accepted",
        "declined",
        "expired",
        "converted",
        "void"
      ]
    },
    "currency": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3
    },
    "lines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "description",
          "quantity",
          "unitPriceCents"
        ],
        "properties": {
          "productId": {
            "type": [
              "string",
              "null"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "quantity": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "unitPriceCents": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}

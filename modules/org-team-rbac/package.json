{
  "name": "@microservices-sh/org-team-rbac",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Prebuilt microservices.sh org-team-rbac module: multi-tenant orgs, memberships, roles, invitations, and a permission-resolution gate enforcing tenant isolation.",
  "exports": {

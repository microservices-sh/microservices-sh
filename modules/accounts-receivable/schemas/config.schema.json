{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Accounts Receivable Module Config",
  "type": "object",
  "properties": {
    "enabled": { "type": "boolean", "default": true },
    "defaultCurrency": { "type": "string", "minLength": 3, "maxLength": 3, "default": "USD" },
    "defaultStatementLookbackDays": { "type": "integer", "minimum": 1, "maximum": 366, "default": 90 },
    "defaultListLimit": { "type": "integer", "minimum": 1, "maximum": 1000, "default": 100 }
  },
  "additionalProperties": false
}

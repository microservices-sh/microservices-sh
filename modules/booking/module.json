{
  "schemaVersion": "2026-06-13",
  "id": "booking",
  "name": "Booking",
  "version": "0.1.0",
  "status": "available",
  "class": "vertical",
  "summary": "Service booking, availability, booking records, domain events, and booking admin data access.",
  "runtime": {
    "language": "typescript",
    "platform": "cloudflare-workers",
    "frameworkNeutral": true,
    "routeAdapters": ["sveltekit", "hono-later"]
  },
  "entrypoint": "src/index.ts",
  "resources": [
    { "type": "d1", "binding": "DB", "tables": ["services", "bookings", "domain_events", "audit_events"] },
    { "type": "kv", "binding": "CACHE_KV", "optional": true }
  ],
  "permissions": ["booking.read", "booking.write", "booking.admin", "booking.extend", "booking.observe"],
  "connections": {
    "requires": ["customer"],
    "optional": ["auth", "audit-log", "payment", "email"],
    "rpc": {
      "exposes": [
        { "method": "listBookings", "scope": "booking.read", "public": false },
        { "method": "getBooking", "scope": "booking.read", "public": false },
        { "method": "getAvailability", "scope": "booking.read", "public": false }
      ],
      "calls": [
        { "target": "customer.getCustomer", "scope": "customer.read" }
      ]
    },
    "events": {
      "emits": ["booking.created", "booking.confirmed", "booking.cancelled"],
      "consumes": ["payment.succeeded"]
    },
    "hookPoints": {
      "calculateAvailability": { "kind": "filter", "scope": "booking.extend" },
      "beforeBookingCreate": { "kind": "filter", "scope": "booking.extend" },
      "afterBookingConfirmed": { "kind": "observer", "scope": "booking.observe" },
      "beforeBookingCancel": { "kind": "guard", "scope": "booking.extend" }
    },
    "provides": { "hooks": [] }
  },
  "customization": {
    "default": "config-hooks",
    "supported": ["config", "hooks", "overlay", "fork"]
  },
  "surfaces": {
    "admin": {
      "applicable": true,
      "nav": [{ "label": "Bookings", "path": "/bookings", "permission": "booking.read", "icon": "CalendarDays" }],
      "referenceUi": ["reference-ui/README.md"]
    },
    "visitor": {
      "applicable": true,
      "featureKey": "spaces",
      "referenceUi": ["reference-ui/README.md"]
    },
    "agentic": {
      "applicable": true,
      "tools": ["booking.listBookings", "booking.getBooking", "booking.getAvailability", "booking.createBooking", "booking.cancelBooking"],
      "skillPaths": ["skills/booking-operator/SKILL.md"],
      "approvalRequiredFor": ["booking.createBooking", "booking.cancelBooking"]
    }
  },
  "skills": [
    {
      "id": "booking-operator",
      "path": "skills/booking-operator/SKILL.md",
      "recommendedFor": ["admin-operations", "visitor-support", "agentic-booking"]
    }
  ],
  "approval": {
    "risk": "medium",
    "requiresApprovalFor": ["migrations", "pii-fields", "production-deploy", "payment-or-email-side-effects"]
  }
}

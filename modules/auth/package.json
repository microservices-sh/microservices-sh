{
  "name": "@microservices-sh/auth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Prebuilt microservices.sh auth module: EdDSA service-token mint/verify, scope guards, JWKS, and signing-key rotation.",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./schemas": "./src/schemas.ts",
    "./hooks": "./src/hooks.ts",
    "./manifest": "./src/manifest/index.ts",
    "./config": "./src/config/index.ts",
    "./schema": "./src/schema/index.ts",
    "./events": "./src/events/index.ts",
    "./permissions": "./src/permissions/index.ts",
    "./resources": "./src/resources/index.ts",
    "./service": "./src/service/index.ts",
    "./deps": "./src/deps.ts",
    "./ports": "./src/ports/index.ts",
    "./rpc": "./src/rpc.ts",
    "./scope": "./src/scope.ts",
    "./jwt": "./src/jwt.ts",
    "./adapters/d1": "./src/adapters/d1-signing-key-store.ts",
    "./adapters/memory": "./src/adapters/memory-signing-key-store.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "check:spec": "node ../../packages/workspace-tools/src/index.js check module --path ."
  },
  "dependencies": {
    "@microservices-sh/connection-contract": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "typescript": "^5.9.3"
  }
}

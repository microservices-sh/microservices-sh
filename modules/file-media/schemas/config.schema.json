{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "File & Media Module Config",
  "type": "object",
  "properties": {
    "allowedContentTypes": {
      "type": "array",
      "items": { "type": "string" },
      "default": ["image/jpeg", "image/png", "image/webp", "image/gif", "image/avif", "application/pdf"]
    },
    "maxBytes": { "type": "integer", "minimum": 1, "default": 10485760 },
    "ticketTtlMs": { "type": "integer", "minimum": 1, "default": 900000 },
    "defaultListLimit": { "type": "integer", "minimum": 1, "maximum": 500, "default": 100 }
  },
  "additionalProperties": false
}

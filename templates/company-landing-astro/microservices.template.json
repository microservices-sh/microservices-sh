{
  "schemaVersion": "2026-06-13",
  "id": "company-landing-astro",
  "version": "0.2.0",
  "status": "ready",
  "displayName": "Company Landing (Astro)",
  "category": "marketing-site",
  "summary": "Static, editorial company landing page on Astro — refined light design, content-driven (src/content.json, agent contract in content.schema.json), zero backend modules.",
  "runtime": {
    "language": "typescript",
    "framework": "astro",
    "adapter": "static",
    "platform": "static",
    "entrypoint": "dist/index.html"
  },
  "deployment": {
    "defaultMode": "static",
    "byoCloudflare": "preferred"
  },
  "modules": {
    "required": [],
    "optional": []
  },
  "interactive": {
    "schema": "intake.schema.json",
    "command": "pnpm microservices setup company-landing-astro",
    "mode": "template-intake",
    "stores": {
      "content": "src/content.json",
      "assets": "public/"
    }
  },
  "skills": [
    {
      "id": "company-web-design",
      "recommendedFor": ["messy-company-input", "brand-copy", "asset-selection"]
    },
    {
      "id": "frontend-design",
      "recommendedFor": ["layout-refresh", "visual-polish"]
    }
  ],
  "slots": {},
  "sourcePolicy": {
    "templateOwns": [
      "app shell",
      "routes",
      "layout",
      "design system (tokens + components)",
      "content shape + types (src/site.config.ts), brand accent derivation"
    ],
    "modulesOwn": [],
    "apiLogic": "none-static-site"
  }
}

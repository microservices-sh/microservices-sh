{
  "schemaVersion": "2026-06-13",
  "id": "notifications-inapp",
  "name": "In-App Notifications",
  "version": "0.1.0",
  "status": "available",
  "class": "provider",
  "summary": "Per-user in-app notification feed: user-scoped lists/counts, read/unread state, polymorphic typed payloads, reconnect catch-up (listSince), and idempotent delivery via dedupKey. Owns persistence; the realtime push layer is the host's concern.",
  "runtime": {
    "language": "typescript",
    "platform": "cloudflare-workers",
    "frameworkNeutral": true,
    "routeAdapters": ["sveltekit", "hono-later"]
  },
  "entrypoint": "src/index.ts",
  "resources": [
    { "type": "d1", "binding": "DB", "tables": ["notifications"] }
  ],
  "permissions": ["notifications.read", "notifications.write", "notifications.admin", "notifications-inapp.extend"],
  "connections": {
    "requires": [],
    "optional": [],
    "rpc": { "exposes": [], "calls": [] },
    "events": {
      "emits": ["notification.created", "notification.read"],
      "consumes": []
    },
    "hookPoints": {
      "beforeNotify": { "kind": "filter", "scope": "notifications-inapp.extend" },
      "renderNotification": { "kind": "filter", "scope": "notifications-inapp.extend" }
    },
    "provides": { "hooks": [] }
  },
  "customization": {
    "default": "config-hooks",
    "supported": ["config", "hooks", "overlay", "fork"]
  },
  "surfaces": {
    "admin": {
      "applicable": true,
      "nav": [{ "label": "Notifications", "path": "/notifications", "permission": "notifications.read", "icon": "Bell" }],
      "referenceUi": ["reference-ui/README.md"]
    },
    "visitor": {
      "applicable": true,
      "featureKey": "notifications",
      "referenceUi": ["reference-ui/README.md"]
    },
    "agentic": {
      "applicable": true,
      "tools": ["notifications-inapp.listNotifications", "notifications-inapp.getUnreadCount", "notifications-inapp.notify", "notifications-inapp.markRead", "notifications-inapp.markAllRead"],
      "skillPaths": ["skills/notifications-inapp-operator/SKILL.md"],
      "approvalRequiredFor": ["notifications-inapp.notify", "notifications-inapp.markRead", "notifications-inapp.markAllRead"]
    }
  },
  "skills": [
    {
      "id": "notifications-inapp-operator",
      "path": "skills/notifications-inapp-operator/SKILL.md",
      "recommendedFor": ["admin-operations", "visitor-notifications", "support-triage"]
    }
  ],
  "approval": {
    "risk": "medium",
    "requiresApprovalFor": ["migrations", "production-deploy"]
  }
}

{
  "schemaVersion": "2026-06-13",
  "id": "dot-ai-os",
  "version": "0.1.0",
  "status": "draft",
  "displayName": "DOT AI OS",
  "category": "business-system",
  "summary": "Agent-native operator OS for Cloudflare SvelteKit: task board, focus plan, calendar context, daily review, knowledge and content pipelines, AI team routing, files, team roles, and business modules behind a lock-driven app shell.",
  "runtime": {
    "language": "typescript",
    "framework": "sveltekit",
    "adapter": "@sveltejs/adapter-cloudflare",
    "platform": "cloudflare-workers",
    "entrypoint": ".svelte-kit/cloudflare/_worker.js"
  },
  "deployment": {
    "defaultMode": "managed-cloudflare",
    "managedNamespace": "microservices-sh",
    "byoCloudflare": "later"
  },
  "modules": {
    "required": [
      "auth",
      "org-team-rbac",
      "admin-shell",
      "audit-log",
      "customer",
      "invoice",
      "file-media",
      "support-ticket",
      "operator-work"
    ],
    "optional": [
      "identity",
      "jobs-workflows",
      "notifications-inapp",
      "email",
      "calendar-google",
      "webhook-delivery"
    ]
  },
  "slots": {
    "identity": {
      "activeModule": "auth",
      "allowedModules": [
        "auth",
        "identity"
      ],
      "approvalRisk": "high"
    },
    "tenancy": {
      "activeModule": "org-team-rbac",
      "allowedModules": [
        "org-team-rbac"
      ],
      "approvalRisk": "high"
    },
    "admin": {
      "activeModule": "admin-shell",
      "allowedModules": [
        "admin-shell"
      ],
      "approvalRisk": "medium"
    },
    "audit": {
      "activeModule": "audit-log",
      "allowedModules": [
        "audit-log"
      ],
      "approvalRisk": "medium"
    },
    "crm": {
      "activeModule": "customer",
      "allowedModules": [
        "customer"
      ],
      "approvalRisk": "medium"
    },
    "support": {
      "activeModule": "support-ticket",
      "allowedModules": [
        "support-ticket"
      ],
      "approvalRisk": "medium"
    },
    "calendar": {
      "activeModule": null,
      "allowedModules": [
        "calendar-google"
      ],
      "approvalRisk": "high"
    },
    "invoicing": {
      "activeModule": "invoice",
      "allowedModules": [
        "invoice"
      ],
      "approvalRisk": "medium"
    },
    "files": {
      "activeModule": "file-media",
      "allowedModules": [
        "file-media"
      ],
      "approvalRisk": "medium"
    },
    "accounts": {
      "activeModule": "identity",
      "allowedModules": [
        "identity"
      ],
      "approvalRisk": "high"
    },
    "jobs": {
      "activeModule": "jobs-workflows",
      "allowedModules": [
        "jobs-workflows"
      ],
      "approvalRisk": "low"
    },
    "operatorWork": {
      "activeModule": "operator-work",
      "allowedModules": [
        "operator-work"
      ],
      "approvalRisk": "medium"
    },
    "notifications": {
      "activeModule": "notifications-inapp",
      "allowedModules": [
        "notifications-inapp"
      ],
      "approvalRisk": "low"
    },
    "messaging": {
      "activeModule": null,
      "allowedModules": [
        "email"
      ],
      "approvalRisk": "high"
    }
  },
  "sourcePolicy": {
    "templateOwns": [
      "app shell",
      "routes",
      "layout",
      "lock-driven sidebar nav",
      "UI overlays",
      "composition glue"
    ],
    "modulesOwn": [
      "domain behavior",
      "schemas",
      "use cases",
      "ports",
      "migrations"
    ],
    "apiLogic": "detached-use-cases-with-sveltekit-adapters"
  },
  "checks": [
    { "id": "migrations", "file": "migrations/0001_core.sql" },
    { "id": "http-smoke", "file": "scripts/smoke-http.mjs" }
  ]
}

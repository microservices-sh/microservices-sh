{
  "name": "@microservices-sh/research",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Research pillar: ingest company knowledge, retrieve by semantic search, and produce cited research briefs (cite-or-refuse).",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./schemas": "./src/schemas.ts",
    "./hooks": "./src/hooks.ts",
    "./manifest": "./src/manifest/index.ts",
    "./config": "./src/config/index.ts",
    "./schema": "./src/schema/index.ts",
    "./events": "./src/events/index.ts",
    "./permissions": "./src/permissions/index.ts",
    "./resources": "./src/resources/index.ts",
    "./service": "./src/service/index.ts",
    "./ports": "./src/ports/index.ts",
    "./graph": "./src/graph.ts",
    "./adapters/d1": "./src/adapters/d1-research-store.ts",
    "./adapters/sqlite-graph": "./src/adapters/sqlite-graph-store.ts",
    "./adapters/node-sqlite-graph": "./src/adapters/node-sqlite-graph.ts",
    "./adapters/libsql-graph": "./src/adapters/libsql-graph.ts",
    "./adapters/sqlite-research-store": "./src/adapters/sqlite-research-store.ts",
    "./adapters/gateway-synthesizer": "./src/adapters/gateway-synthesizer.ts",
    "./adapters/memory": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "check:spec": "node ../../packages/workspace-tools/src/index.js check module --path ."
  },
  "dependencies": { "zod": "^4.4.3" },
  "devDependencies": { "@cloudflare/workers-types": "^4.20250109.0", "typescript": "^5.9.3" }
}

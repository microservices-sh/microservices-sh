{
  "openapi": "3.1.0",
  "info": {
    "title": "Accounts Payable Module",
    "version": "0.1.0",
    "description": "Boundary shapes for tenant-scoped vendors, bills, payment applications, and aging."
  },
  "paths": {
    "/vendors": {
      "post": {
        "summary": "Create vendor",
        "responses": { "201": { "description": "Vendor created" } }
      },
      "get": {
        "summary": "List vendors",
        "responses": { "200": { "description": "Vendor list" } }
      }
    },
    "/vendors/{id}": {
      "get": {
        "summary": "Get vendor",
        "responses": { "200": { "description": "Vendor detail" }, "404": { "description": "Vendor not found" } }
      },
      "patch": {
        "summary": "Update vendor master data",
        "responses": { "200": { "description": "Vendor updated" }, "409": { "description": "External reference conflict" } }
      }
    },
    "/vendors/{id}/status": {
      "post": {
        "summary": "Activate or deactivate vendor",
        "responses": { "200": { "description": "Vendor status updated" }, "404": { "description": "Vendor not found" } }
      }
    },
    "/vendors/1099-report": {
      "get": {
        "summary": "Get 1099 readiness report for active 1099 vendors by calendar year",
        "responses": { "200": { "description": "1099 readiness report" } }
      }
    },
    "/bills": {
      "post": {
        "summary": "Create bill with line items",
        "responses": { "201": { "description": "Bill created" }, "422": { "description": "Invalid totals" } }
      },
      "get": {
        "summary": "List bills",
        "responses": { "200": { "description": "Bill list" } }
      }
    },
    "/bills/{id}/payable": {
      "post": {
        "summary": "Approve or mark bill payable without requiring accounting posting",
        "responses": { "200": { "description": "Bill marked payable" }, "409": { "description": "Invalid status" } }
      }
    },
    "/bills/{id}/post": {
      "post": {
        "summary": "Post an approved bill to accounting",
        "responses": { "200": { "description": "Bill posted to accounting" }, "409": { "description": "Bill not approved or already paid" } }
      }
    },
    "/bills/{id}/void": {
      "post": {
        "summary": "Void an unpaid, unposted bill",
        "responses": { "200": { "description": "Bill voided" }, "409": { "description": "Bill has payments or needs accounting reversal" } }
      }
    },
    "/bill-payments": {
      "post": {
        "summary": "Record bill payment and applications",
        "responses": { "201": { "description": "Payment recorded" }, "409": { "description": "Overpayment or duplicate guard" } }
      },
      "get": {
        "summary": "List bill payments by tenant, vendor, bill, or status",
        "responses": { "200": { "description": "Bill payment list" } }
      }
    },
    "/bill-payments/{id}": {
      "get": {
        "summary": "Get bill payment with applications",
        "responses": { "200": { "description": "Bill payment detail" }, "404": { "description": "Payment not found" } }
      }
    },
    "/aging": {
      "get": {
        "summary": "Open balance aging report",
        "responses": { "200": { "description": "Aging report" } }
      }
    },
    "/recurring-bill-templates": {
      "post": {
        "summary": "Create recurring bill template",
        "responses": { "201": { "description": "Recurring bill template created" }, "422": { "description": "Invalid totals" } }
      },
      "get": {
        "summary": "List recurring bill templates",
        "responses": { "200": { "description": "Recurring bill template list" } }
      }
    },
    "/recurring-bill-templates/{id}/status": {
      "post": {
        "summary": "Pause, resume, cancel, or complete a recurring bill template",
        "responses": { "200": { "description": "Recurring bill template status updated" }, "409": { "description": "Invalid status transition" } }
      }
    },
    "/recurring-bill-templates/generate-due": {
      "post": {
        "summary": "Generate bills for active due recurring bill templates",
        "responses": {
          "200": { "description": "No due templates or idempotent replay handled" },
          "201": { "description": "Due recurring bills generated" },
          "400": { "description": "Invalid generation input" }
        }
      }
    }
  }
}

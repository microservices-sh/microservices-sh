{
  "name": "@microservices-sh/gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Prebuilt microservices.sh gateway module: API-key authentication, rate limiting, scope narrowing, and token exchange via auth.",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./schemas": "./src/schemas.ts",
    "./hooks": "./src/hooks.ts",
    "./manifest": "./src/manifest/index.ts",
    "./config": "./src/config/index.ts",
    "./schema": "./src/schema/index.ts",
    "./events": "./src/events/index.ts",
    "./permissions": "./src/permissions/index.ts",
    "./resources": "./src/resources/index.ts",
    "./service": "./src/service/index.ts",
    "./ports": "./src/ports/index.ts",
    "./crypto": "./src/crypto.ts",
    "./adapters/d1": "./src/adapters/d1-api-key-store.ts",
    "./adapters/memory": "./src/adapters/memory-api-key-store.ts",
    "./adapters/kv-rate-limit": "./src/adapters/kv-rate-limit-store.ts",
    "./adapters/memory-rate-limit": "./src/adapters/memory-rate-limit-store.ts",
    "./adapters/token-minter": "./src/adapters/auth-token-minter.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "check:spec": "node ../../packages/workspace-tools/src/index.js check module --path ."
  },
  "dependencies": {
    "@microservices-sh/auth": "workspace:*",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "typescript": "^5.9.3"
  }
}

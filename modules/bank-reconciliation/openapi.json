{
  "openapi": "3.1.0",
  "info": {
    "title": "Bank Reconciliation Module",
    "version": "0.1.0",
    "description": "Tenant-scoped bank accounts, statement imports, matching, and reconciliation completion."
  },
  "paths": {
    "/bank-accounts": {
      "get": {
        "summary": "List bank accounts",
        "operationId": "listBankAccounts"
      },
      "post": {
        "summary": "Create a bank account",
        "operationId": "createBankAccount"
      }
    },
    "/statement-import-mapping-presets": {
      "get": {
        "summary": "List CSV field mapping presets",
        "operationId": "listStatementImportFieldMappingPresets",
        "responses": {
          "200": {
            "description": "Available field mapping presets",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/StatementImportMappingPreset" }
                }
              }
            }
          }
        }
      }
    },
    "/statement-import-mapping-detection": {
      "post": {
        "summary": "Detect CSV field mapping from statement headers",
        "operationId": "detectStatementImportFieldMapping",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["csvContent"],
                "properties": {
                  "csvContent": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Detected field mapping",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatementImportFieldMapping" }
              }
            }
          }
        }
      }
    },
    "/statement-imports": {
      "get": {
        "summary": "List statement imports",
        "operationId": "listStatementImports"
      },
      "post": {
        "summary": "Import a mapped CSV statement",
        "operationId": "importStatementCsv",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ImportStatementCsvRequest" }
            }
          }
        }
      }
    },
    "/statement-imports/preview": {
      "post": {
        "summary": "Preview a mapped CSV statement without persisting imports or transactions",
        "operationId": "previewStatementImportCsv",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PreviewStatementImportCsvRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "CSV statement import preview",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BankStatementImportPreview" }
              }
            }
          }
        }
      }
    },
    "/statement-transactions/import": {
      "post": {
        "summary": "Import prepared statement transactions",
        "operationId": "importStatementTransactions"
      }
    },
    "/statement-transactions": {
      "get": {
        "summary": "List statement transactions",
        "operationId": "listStatementTransactions"
      }
    },
    "/matches/suggest": {
      "post": {
        "summary": "Suggest matches against ledger or payment candidates",
        "operationId": "suggestMatches",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SuggestMatchesRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ranked match suggestions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/MatchSuggestion" }
                }
              }
            }
          }
        }
      }
    },
    "/matches": {
      "post": {
        "summary": "Create a reconciliation match",
        "operationId": "createMatch",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateMatchRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created match",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateMatchResult" }
              }
            }
          }
        }
      }
    },
    "/matches/unmatch": {
      "post": {
        "summary": "Remove one or all matches from a statement transaction",
        "operationId": "unmatchTransaction"
      }
    },
    "/transactions/exclude": {
      "post": {
        "summary": "Exclude a statement transaction from reconciliation",
        "operationId": "excludeTransaction"
      }
    },
    "/transactions/restore-excluded": {
      "post": {
        "summary": "Restore an excluded statement transaction to unmatched",
        "operationId": "restoreExcludedTransaction"
      }
    },
    "/reconciliations": {
      "get": {
        "summary": "List reconciliation sessions",
        "operationId": "listReconciliations"
      },
      "post": {
        "summary": "Start a reconciliation session",
        "operationId": "startReconciliation"
      }
    },
    "/reconciliations/{id}/complete": {
      "post": {
        "summary": "Complete a reconciliation session",
        "operationId": "completeReconciliation"
      }
    }
  },
  "components": {
    "schemas": {
      "MoneyCents": {
        "type": "integer",
        "description": "Signed integer cents. Deposits are positive and withdrawals are negative."
      },
      "MatchTargetType": {
        "type": "string",
        "enum": ["ledger_entry", "ledger_line", "payment", "external_ref"]
      },
      "StatementImportFieldMappingPresetId": {
        "type": "string",
        "enum": ["standard_amount", "details_debit_credit", "posted_amount"]
      },
      "StatementImportFieldMapping": {
        "type": "object",
        "required": ["date", "description"],
        "properties": {
          "presetId": { "$ref": "#/components/schemas/StatementImportFieldMappingPresetId" },
          "autoDetected": { "type": "boolean" },
          "date": { "type": "string" },
          "description": { "type": "string" },
          "amount": { "type": "string" },
          "debit": { "type": "string" },
          "credit": { "type": "string" }
        },
        "oneOf": [
          { "required": ["amount"] },
          { "required": ["debit", "credit"] }
        ]
      },
      "StatementImportMappingPreset": {
        "type": "object",
        "required": ["id", "label", "description", "fieldMapping"],
        "properties": {
          "id": { "$ref": "#/components/schemas/StatementImportFieldMappingPresetId" },
          "label": { "type": "string" },
          "description": { "type": "string" },
          "fieldMapping": { "$ref": "#/components/schemas/StatementImportFieldMapping" }
        }
      },
      "ImportStatementCsvRequest": {
        "type": "object",
        "required": ["tenantId", "bankAccountId", "csvContent"],
        "properties": {
          "tenantId": { "type": "string" },
          "bankAccountId": { "type": "string" },
          "source": { "type": "string", "enum": ["csv", "ofx", "qfx", "qif", "api"], "default": "csv" },
          "fileName": { "type": ["string", "null"] },
          "importedById": { "type": ["string", "null"] },
          "fieldMapping": { "$ref": "#/components/schemas/StatementImportFieldMapping" },
          "fieldMappingPresetId": { "$ref": "#/components/schemas/StatementImportFieldMappingPresetId" },
          "autoDetectFieldMapping": { "type": "boolean" },
          "csvContent": { "type": "string" }
        },
        "anyOf": [
          { "required": ["fieldMapping"] },
          { "required": ["fieldMappingPresetId"] },
          { "required": ["autoDetectFieldMapping"] }
        ]
      },
      "PreviewStatementImportCsvRequest": {
        "allOf": [
          { "$ref": "#/components/schemas/ImportStatementCsvRequest" },
          {
            "type": "object",
            "properties": {
              "previewLimit": { "type": ["integer", "null"], "minimum": 1, "maximum": 100, "default": 25 }
            }
          }
        ]
      },
      "BankStatementImportPreviewRow": {
        "type": "object",
        "required": ["rowNumber", "status"],
        "properties": {
          "rowNumber": { "type": "integer", "minimum": 2 },
          "status": { "type": "string", "enum": ["importable", "duplicate", "skipped"] },
          "transactionDate": { "type": "string", "format": "date" },
          "description": { "type": "string" },
          "amountCents": { "$ref": "#/components/schemas/MoneyCents" },
          "transactionHash": { "type": "string" },
          "duplicateTransactionId": { "type": "string" },
          "errorCode": { "type": "string" },
          "errorMessage": { "type": "string" }
        }
      },
      "BankStatementImportPreview": {
        "type": "object",
        "required": ["totalRows", "importableRows", "duplicateRows", "skippedRows", "truncated", "previewLimit", "fieldMapping", "rows"],
        "properties": {
          "totalRows": { "type": "integer", "minimum": 0 },
          "importableRows": { "type": "integer", "minimum": 0 },
          "duplicateRows": { "type": "integer", "minimum": 0 },
          "skippedRows": { "type": "integer", "minimum": 0 },
          "truncated": { "type": "boolean" },
          "previewLimit": { "type": "integer", "minimum": 1, "maximum": 100 },
          "fieldMapping": { "$ref": "#/components/schemas/StatementImportFieldMapping" },
          "rows": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/BankStatementImportPreviewRow" }
          }
        }
      },
      "MatchCandidate": {
        "type": "object",
        "required": ["targetType", "targetId", "amountCents"],
        "properties": {
          "targetType": { "$ref": "#/components/schemas/MatchTargetType" },
          "targetId": { "type": "string" },
          "targetRef": { "type": ["string", "null"] },
          "targetDate": { "type": ["string", "null"], "format": "date" },
          "amountCents": { "$ref": "#/components/schemas/MoneyCents" },
          "description": { "type": ["string", "null"] },
          "source": { "type": ["string", "null"] },
          "metadata": { "type": "object", "additionalProperties": true }
        }
      },
      "MatchSuggestion": {
        "allOf": [
          { "$ref": "#/components/schemas/MatchCandidate" },
          {
            "type": "object",
            "required": ["amountDeltaCents", "confidence", "reasons"],
            "properties": {
              "amountDeltaCents": { "$ref": "#/components/schemas/MoneyCents" },
              "dateDeltaDays": { "type": ["integer", "null"] },
              "confidence": { "type": "integer", "minimum": 0, "maximum": 100 },
              "reasons": { "type": "array", "items": { "type": "string" } }
            }
          }
        ]
      },
      "SuggestMatchesRequest": {
        "type": "object",
        "required": ["tenantId", "transactionId"],
        "properties": {
          "tenantId": { "type": "string" },
          "transactionId": { "type": "string" },
          "candidates": { "type": "array", "items": { "$ref": "#/components/schemas/MatchCandidate" } },
          "dateToleranceDays": { "type": "integer", "minimum": 0, "maximum": 30, "default": 3 },
          "amountToleranceCents": { "$ref": "#/components/schemas/MoneyCents" },
          "limit": { "type": "integer", "minimum": 1, "maximum": 100, "default": 10 }
        }
      },
      "CreateMatchRequest": {
        "type": "object",
        "required": ["tenantId", "transactionId", "targetType", "targetId", "targetAmountCents"],
        "properties": {
          "tenantId": { "type": "string" },
          "transactionId": { "type": "string" },
          "targetType": { "$ref": "#/components/schemas/MatchTargetType" },
          "targetId": { "type": "string" },
          "targetRef": { "type": ["string", "null"] },
          "targetDate": { "type": ["string", "null"], "format": "date" },
          "targetAmountCents": { "$ref": "#/components/schemas/MoneyCents" },
          "description": { "type": ["string", "null"] },
          "matchType": { "type": "string", "enum": ["auto", "manual", "rule"], "default": "manual" },
          "confidence": { "type": ["integer", "null"], "minimum": 0, "maximum": 100 },
          "reconciliationId": { "type": ["string", "null"] }
        }
      },
      "BankTransactionMatch": {
        "type": "object",
        "required": ["id", "tenantId", "bankTransactionId", "targetType", "targetId", "targetAmountCents", "matchType", "amountMatchedCents", "confirmed", "createdAt"],
        "properties": {
          "id": { "type": "string" },
          "tenantId": { "type": "string" },
          "bankTransactionId": { "type": "string" },
          "targetType": { "$ref": "#/components/schemas/MatchTargetType" },
          "targetId": { "type": "string" },
          "targetRef": { "type": ["string", "null"] },
          "targetDate": { "type": ["string", "null"], "format": "date" },
          "targetAmountCents": { "$ref": "#/components/schemas/MoneyCents" },
          "description": { "type": ["string", "null"] },
          "matchType": { "type": "string", "enum": ["auto", "manual", "rule"] },
          "confidence": { "type": ["integer", "null"], "minimum": 0, "maximum": 100 },
          "amountMatchedCents": { "$ref": "#/components/schemas/MoneyCents" },
          "confirmed": { "type": "boolean" },
          "confirmedAt": { "type": ["string", "null"] },
          "confirmedById": { "type": ["string", "null"] },
          "reconciliationId": { "type": ["string", "null"] },
          "createdAt": { "type": "string" }
        }
      },
      "CreateMatchResult": {
        "type": "object",
        "required": ["match"],
        "properties": {
          "match": { "$ref": "#/components/schemas/BankTransactionMatch" }
        }
      }
    }
  }
}

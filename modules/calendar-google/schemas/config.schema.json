{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Google Calendar Module Config",
  "type": "object",
  "properties": {
    "defaultCalendarId": { "type": "string", "default": "primary" },
    "earlyRefreshMs": { "type": "integer", "minimum": 0, "default": 60000 },
    "refreshLeaseMs": { "type": "integer", "minimum": 1, "default": 15000 },
    "channelRenewWithinMs": { "type": "integer", "minimum": 1, "default": 86400000 },
    "channelTtlMs": { "type": "integer", "minimum": 1, "default": 604800000 },
    "defaultMaxPages": { "type": "integer", "minimum": 1, "maximum": 50, "default": 10 },
    "defaultListLimit": { "type": "integer", "minimum": 1, "maximum": 500, "default": 100 }
  },
  "additionalProperties": false
}

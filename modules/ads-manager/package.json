{
  "name": "@microservices-sh/ads-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Prebuilt microservices.sh ads-manager module: cross-platform ad monitoring (Meta, Google) over an upstream ads service, D1 insight snapshots, anomaly alerts, entitlement-gated paid connector.",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./schemas": "./src/schemas.ts",
    "./hooks": "./src/hooks.ts",
    "./manifest": "./src/manifest/index.ts",
    "./config": "./src/config/index.ts",
    "./schema": "./src/schema/index.ts",
    "./events": "./src/events/index.ts",
    "./permissions": "./src/permissions/index.ts",
    "./resources": "./src/resources/index.ts",
    "./service": "./src/service/index.ts",
    "./ports": "./src/ports/index.ts",
    "./keys": "./src/keys.ts",
    "./adapters/d1": "./src/adapters/d1-ads-store.ts",
    "./adapters/memory": "./src/adapters/memory-ads-store.ts",
    "./adapters/memory-connector": "./src/adapters/memory-connector.ts",
    "./adapters/openclaw": "./src/adapters/openclaw-connector.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "check:spec": "node ../../packages/workspace-tools/src/index.js check module --path .",
    "test": "vitest run"
  },
  "dependencies": {
    "@microservices-sh/connection-contract": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "typescript": "^5.9.3"
  }
}

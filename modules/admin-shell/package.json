{
  "name": "@microservices-sh/admin-shell",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Prebuilt microservices.sh admin-shell module: schema-driven CRUD over existing D1 tables with RBAC, soft-delete, search/pagination, and audit hooks.",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./schemas": "./src/schemas.ts",
    "./hooks": "./src/hooks.ts",
    "./manifest": "./src/manifest/index.ts",
    "./config": "./src/config/index.ts",
    "./schema": "./src/schema/index.ts",
    "./events": "./src/events/index.ts",
    "./permissions": "./src/permissions/index.ts",
    "./resources": "./src/resources/index.ts",
    "./service": "./src/service/index.ts",
    "./ports": "./src/ports/index.ts",
    "./registry": "./src/registry.ts",
    "./authz": "./src/authz.ts",
    "./adapters/d1": "./src/adapters/d1-table-gateway.ts",
    "./adapters/memory": "./src/adapters/memory-table-gateway.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "build:dist": "node scripts/build-dist.mjs",
    "check:spec": "node ../../packages/workspace-tools/src/index.js check module --path .",
    "test": "vitest run"
  },
  "dependencies": {
    "@microservices-sh/connection-contract": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3"
  },
  "files": ["dist"],
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": "./dist/index.js",
      "./types": "./dist/types.js",
      "./schemas": "./dist/schemas.js",
      "./hooks": "./dist/hooks.js",
      "./registry": "./dist/registry.js",
      "./authz": "./dist/authz.js",
      "./adapters/d1": "./dist/adapters/d1.js",
      "./adapters/memory": "./dist/adapters/memory.js"
    }
  }
}

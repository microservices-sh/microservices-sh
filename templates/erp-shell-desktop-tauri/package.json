{
  "name": "@microservices-sh/template-erp-shell-desktop-tauri",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Desktop companion MVP for the ERP shell: local document intake, extraction queue, and approved-draft ERP import for macOS and Windows.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",

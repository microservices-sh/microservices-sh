{
  "openapi": "3.1.0",
  "info": {
    "title": "Invoice Module",
    "version": "0.1.0",
    "description": "Invoices with atomic numbering, lifecycle enforcement, and idempotent payments. Routes are owned by the host app; these are the boundary shapes."
  },
  "paths": {
    "/invoices": {
      "post": {
        "summary": "Create a draft invoice",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["tenantId", "customerId"],
                "properties": {
                  "tenantId": { "type": "string" },
                  "customerId": { "type": "string" },
                  "currency": { "type": "string" },
                  "series": { "type": "string" },
                  "notes": { "type": "string" },
                  "lineItems": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["description", "unitAmountCents"],
                      "properties": {
                        "description": { "type": "string" },
                        "quantity": { "type": "integer", "minimum": 1 },
                        "unitAmountCents": { "type": "integer" },
                        "taxRateBps": { "type": "integer", "minimum": 0 }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Draft created" } }
      },
      "get": {
        "summary": "List invoices (tenant-scoped)",
        "parameters": [
          { "name": "tenantId", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "customerId", "in": "query", "schema": { "type": "string" } },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["draft", "open", "paid", "void"] } }
        ],
        "responses": { "200": { "description": "Invoice list" } }
      }
    },
    "/invoices/{id}/issue": {
      "post": {
        "summary": "Issue a draft (assigns atomic number, freezes totals)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "201": { "description": "Issued" },
          "200": { "description": "Already issued" },
          "422": { "description": "No line items" }
        }
      }
    },
    "/invoices/{id}/payments": {
      "post": {
        "summary": "Record a payment (idempotent on idempotencyKey)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["amountCents"],
                "properties": {
                  "amountCents": { "type": "integer", "minimum": 1 },
                  "idempotencyKey": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Payment applied (or deduplicated)" } }
      }
    },
    "/invoices/{id}/payment-link": {
      "post": {
        "summary": "Create or return an invoice payment link",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "successUrl": { "type": "string", "format": "uri" },
                  "customerEmail": { "type": "string", "format": "email" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Payment link created" },
          "200": { "description": "Existing payment link returned" },
          "409": { "description": "Invoice is not payable" }
        }
      }
    },
    "/invoices/recurring": {
      "post": {
        "summary": "Create a recurring invoice template",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["tenantId", "customerId", "name", "startAt", "lineItems"],
                "properties": {
                  "tenantId": { "type": "string" },
                  "customerId": { "type": "string" },
                  "name": { "type": "string" },
                  "currency": { "type": "string" },
                  "series": { "type": "string" },
                  "frequency": {
                    "type": "string",
                    "enum": ["weekly", "monthly", "quarterly", "yearly", "custom"]
                  },
                  "customDays": { "type": "integer", "minimum": 1 },
                  "startAt": { "type": "string", "format": "date-time" },
                  "endAt": { "type": "string", "format": "date-time" },
                  "paymentTermsDays": { "type": "integer", "minimum": 0 },
                  "maxOccurrences": { "type": "integer", "minimum": 1 },
                  "autoIssue": { "type": "boolean" },
                  "notes": { "type": "string" },
                  "lineItems": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "required": ["description", "unitAmountCents"],
                      "properties": {
                        "description": { "type": "string" },
                        "quantity": { "type": "integer", "minimum": 1 },
                        "unitAmountCents": { "type": "integer" },
                        "taxRateBps": { "type": "integer", "minimum": 0 }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Recurring template created" } }
      },
      "get": {
        "summary": "List recurring invoice templates",
        "parameters": [
          { "name": "tenantId", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "customerId", "in": "query", "schema": { "type": "string" } },
          {
            "name": "status",
            "in": "query",
            "schema": { "type": "string", "enum": ["active", "paused", "cancelled", "completed"] }
          },
          { "name": "dueOnOrBefore", "in": "query", "schema": { "type": "string", "format": "date-time" } }
        ],
        "responses": { "200": { "description": "Recurring template list" } }
      }
    },
    "/invoices/recurring/generate-due": {
      "post": {
        "summary": "Generate invoices for due recurring templates",
        "responses": {
          "201": { "description": "One or more invoices created" },
          "200": { "description": "No new invoices created or only existing occurrences recovered" }
        }
      }
    },
    "/invoices/recurring/{id}/status": {
      "post": {
        "summary": "Pause, resume, cancel, or complete a recurring template",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["status"],
                "properties": {
                  "status": { "type": "string", "enum": ["active", "paused", "cancelled", "completed"] }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Status updated" }, "409": { "description": "Invalid transition" } }
      }
    }
  }
}

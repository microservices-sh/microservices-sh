{
  "schemaVersion": "2026-06-13",
  "id": "invoice",
  "name": "Invoice",
  "version": "0.1.0",
  "status": "available",
  "class": "core",
  "summary": "Invoices with gapless atomic numbering, per-line tax, an enforced draft->open->paid->void lifecycle, idempotent payment application, and dunning hooks.",
  "runtime": {
    "language": "typescript",
    "platform": "cloudflare-workers",
    "frameworkNeutral": true,
    "routeAdapters": ["sveltekit", "hono-later"]
  },
  "entrypoint": "src/index.ts",
  "resources": [
    { "type": "d1", "binding": "DB", "tables": ["invoices", "invoice_line_items", "invoice_sequences", "invoice_payments"] }
  ],
  "permissions": ["invoice.read", "invoice.write", "invoice.admin"],
  "requires": ["customer"],
  "optional": ["payment", "email", "audit-log", "jobs-workflows"],
  "hooks": ["beforeInvoiceIssue", "onInvoiceIssued", "onInvoicePaid"],
  "events": ["invoice.created", "invoice.issued", "invoice.paid", "invoice.voided", "invoice.overdue"],
  "rpc": [],
  "customization": {
    "default": "config-hooks",
    "supported": ["config", "hooks", "overlay", "fork"]
  },
  "approval": {
    "risk": "high",
    "requiresApprovalFor": ["migrations", "money-mutations", "production-deploy"]
  }
}

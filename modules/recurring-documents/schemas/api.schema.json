{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Recurring Documents API",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "documentType": {
      "type": "string",
      "enum": [
        "invoice",
        "bill"
      ]
    },
    "partyId": {
      "type": "string",
      "minLength": 1
    },
    "frequency": {
      "type": "string",
      "enum": [
        "weekly",
        "monthly",
        "quarterly",
        "yearly",
        "custom"
      ]
    },
    "customDays": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "lines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "description",
          "quantity",
          "unitPriceCents"
        ],
        "properties": {
          "description": {
            "type": "string",
            "minLength": 1
          },
          "quantity": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "unitPriceCents": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}

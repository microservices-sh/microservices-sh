{
  "schemaVersion": "2026-06-13",
  "id": "invoice",
  "name": "Invoice",
  "version": "0.1.0",
  "status": "available",
  "class": "core",
  "summary": "Invoices with gapless atomic numbering, per-line tax, an enforced draft->open->paid->void lifecycle, idempotent payment application, payment-link metadata, and dunning hooks.",
  "runtime": {
    "language": "typescript",
    "platform": "cloudflare-workers",
    "frameworkNeutral": true,
    "routeAdapters": ["sveltekit", "hono-later"]
  },
  "entrypoint": "src/index.ts",
  "resources": [
    { "type": "d1", "binding": "DB", "tables": ["invoices", "invoice_line_items", "invoice_sequences", "invoice_payments"] }
  ],
  "permissions": ["invoice.read", "invoice.write", "invoice.admin", "invoice.extend", "invoice.observe"],
  "connections": {
    "requires": ["customer"],
    "optional": ["payment", "email", "audit-log", "jobs-workflows"],
    "rpc": {
      "exposes": [],
      "calls": []
    },
    "events": {
      "emits": [
        "invoice.created",
        "invoice.issued",
        "invoice.paid",
        "invoice.voided",
        "invoice.overdue",
        "invoice.payment_link_created"
      ],
      "consumes": []
    },
    "hookPoints": {
      "beforeInvoiceIssue": { "kind": "filter", "scope": "invoice.extend" },
      "onInvoiceIssued": { "kind": "observer", "scope": "invoice.observe" },
      "onInvoicePaid": { "kind": "observer", "scope": "invoice.observe" }
    },
    "provides": { "hooks": [] }
  },
  "customization": {
    "default": "config-hooks",
    "supported": ["config", "hooks", "overlay", "fork"]
  },
  "surfaces": {
    "admin": {
      "applicable": true,
      "nav": [{ "label": "Invoices", "path": "/invoices", "permission": "invoice.read", "icon": "FileText" }],
      "referenceUi": ["reference-ui/README.md"]
    },
    "visitor": {
      "applicable": true,
      "featureKey": "invoices",
      "referenceUi": ["reference-ui/README.md"]
    },
    "agentic": {
      "applicable": true,
      "tools": [
        "invoice.listInvoices",
        "invoice.getInvoice",
        "invoice.issueInvoice",
        "invoice.recordPayment",
        "invoice.createPaymentLink",
        "invoice.voidInvoice"
      ],
      "skillPaths": ["skills/invoice-operator/SKILL.md"],
      "approvalRequiredFor": [
        "invoice.issueInvoice",
        "invoice.recordPayment",
        "invoice.createPaymentLink",
        "invoice.voidInvoice"
      ]
    }
  },
  "skills": [
    {
      "id": "invoice-operator",
      "path": "skills/invoice-operator/SKILL.md",
      "recommendedFor": ["admin-operations", "billing-support", "money-mutations"]
    }
  ],
  "approval": {
    "risk": "high",
    "requiresApprovalFor": ["migrations", "money-mutations", "production-deploy"]
  }
}

{
  "schemaVersion": "2026-06-13",
  "id": "webhook-delivery",
  "name": "Webhook Delivery",
  "version": "0.1.0",
  "status": "available",
  "class": "sink",
  "summary": "Outbound mirror of the event bus: registers external endpoints (per-endpoint signing secret), delivers HMAC-signed domain events, and logs delivery attempts.",
  "runtime": {
    "language": "typescript",
    "platform": "cloudflare-workers",
    "frameworkNeutral": true,
    "routeAdapters": ["sveltekit", "hono-later"]
  },
  "entrypoint": "src/index.ts",
  "resources": [
    { "type": "d1", "binding": "DB", "tables": ["webhook_endpoints", "webhook_deliveries"] }
  ],
  "permissions": ["webhook.read", "webhook.write", "webhook.admin", "webhook-delivery.extend"],
  "connections": {
    "requires": [],
    "optional": ["auth", "customer", "booking", "payment", "audit-log"],
    "rpc": { "exposes": [], "calls": [] },
    "events": {
      "emits": ["webhook.delivered", "webhook.failed"],
      "consumes": [
        "auth.token_minted",
        "auth.key_rotated",
        "customer.created",
        "customer.updated",
        "booking.created",
        "booking.confirmed",
        "booking.cancelled",
        "payment.checkout_created",
        "payment.succeeded",
        "payment.refunded",
        "payment.failed"
      ]
    },
    "hookPoints": {
      "beforeWebhookDeliver": { "kind": "filter", "scope": "webhook-delivery.extend" },
      "afterWebhookDelivered": { "kind": "observer", "scope": "webhook-delivery.extend" }
    },
    "provides": { "hooks": [] }
  },
  "customization": {
    "default": "config-hooks",
    "supported": ["config", "hooks", "overlay", "fork"]
  },
  "surfaces": {
    "admin": {
      "applicable": true,
      "nav": [{ "label": "Webhooks", "path": "/settings/webhooks", "permission": "webhook.read", "icon": "Webhook" }],
      "referenceUi": ["reference-ui/README.md"]
    },
    "visitor": {
      "applicable": false
    },
    "agentic": {
      "applicable": true,
      "tools": ["webhook-delivery.registerEndpoint", "webhook-delivery.listEndpoints", "webhook-delivery.listDeliveries", "webhook-delivery.deliverEvent"],
      "skillPaths": ["skills/webhook-delivery-operator/SKILL.md"],
      "approvalRequiredFor": ["webhook-delivery.registerEndpoint", "webhook-delivery.deliverEvent"]
    }
  },
  "skills": [
    {
      "id": "webhook-delivery-operator",
      "path": "skills/webhook-delivery-operator/SKILL.md",
      "recommendedFor": ["admin-operations", "webhook-management", "external-side-effects"]
    }
  ],
  "approval": {
    "risk": "high",
    "requiresApprovalFor": ["migrations", "external-side-effects", "production-deploy"]
  }
}

{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "commerce-ops-sveltekit",
  "main": ".svelte-kit/cloudflare/_worker.js",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".svelte-kit/cloudflare",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "triggers": {
    "crons": [
      "*/5 * * * *"
    ]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "commerce_ops_sveltekit",
      "database_id": "REPLACE_WITH_D1_ID",
      "migrations_dir": "migrations"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "RATE_LIMIT_KV",
      "id": "REPLACE_WITH_RATE_LIMIT_KV_ID"
    }
  ],
  "r2_buckets": [
    {
      "binding": "MEDIA_BUCKET",
      "bucket_name": "commerce-ops-sveltekit-files"
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "JOB_QUEUE",
        "queue": "commerce-ops-sveltekit-jobs"
      }
    ]
  },
  "vars": {
    "DESKTOP_IMPORT_ALLOWED_ORIGIN": "*",
    "MICROSERVICES_DEPLOYMENT_ID": "",
    "MICROSERVICES_OBSERVABILITY_URL": "https://api.microservices.sh",
    "MICROSERVICES_TEMPLATE_ID": "commerce-ops-sveltekit"
  }
}

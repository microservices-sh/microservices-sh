{
  "name": "@microservices-sh/identity",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Passwordless email-code identity + server-side sessions, built on @microservices-sh/auth (no third-party auth dep, no zod migration). Bridges to the auth module for scoped service tokens.",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./schemas": "./src/schemas.ts",
    "./hooks": "./src/hooks.ts",
    "./manifest": "./src/manifest/index.ts",
    "./config": "./src/config/index.ts",
    "./schema": "./src/schema/index.ts",
    "./events": "./src/events/index.ts",
    "./permissions": "./src/permissions/index.ts",
    "./resources": "./src/resources/index.ts",
    "./service": "./src/service/index.ts",
    "./ports": "./src/ports/index.ts",
    "./bridge": "./src/bridge.ts",
    "./session": "./src/session.ts",
    "./adapters/memory": "./src/adapters/memory.ts",
    "./adapters/d1": "./src/adapters/d1.ts"
  },
  "scripts": {
    "test": "vitest run",
    "build": "tsc --noEmit -p tsconfig.json",
    "check:spec": "node ../../packages/workspace-tools/src/index.js check module --path ."
  },
  "dependencies": {
    "@microservices-sh/auth": "workspace:*",
    "@microservices-sh/connection-contract": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "typescript": "^5.9.3",
    "vitest": "^1.2.0"
  }
}

{
  "name": "@microservices-sh/cli",
  "version": "0.1.0",
  "description": "The microservices.sh CLI — scaffold, compose, check, and deploy governed Cloudflare apps.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/microservices-sh/microservices-sh.git",
    "directory": "packages/cli"
  },
  "homepage": "https://microservices.sh",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "microservices": "src/index.js"
  },
  "files": [
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "cli": "node src/index.js",
    "build": "node --check src/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@microservices-sh/connection-contract": "workspace:*",
    "@microservices-sh/sdk-internal": "workspace:*"
  },
  "devDependencies": {
    "@microservices-sh/ops-token": "workspace:*"
  }
}

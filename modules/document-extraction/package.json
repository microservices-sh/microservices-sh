{
  "name": "@microservices-sh/document-extraction",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Document extraction with local-first OCR, schema-normalized drafts, human review, and governed AI fallback.",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./schemas": "./src/schemas.ts",
    "./http": "./src/http.ts",
    "./hooks": "./src/hooks.ts",
    "./manifest": "./src/manifest/index.ts",
    "./config": "./src/config/index.ts",
    "./schema": "./src/schema/index.ts",
    "./events": "./src/events/index.ts",
    "./permissions": "./src/permissions/index.ts",
    "./resources": "./src/resources/index.ts",
    "./service": "./src/service/index.ts",
    "./ports": "./src/ports/index.ts",
    "./preview": "./reference-ui/Preview.svelte",
    "./adapters/d1": "./src/adapters/d1-document-extraction-store.ts",
    "./adapters/memory": "./src/adapters/memory-document-extraction-store.ts",
    "./adapters/gemma-normalizer": "./src/adapters/gemma-normalizer.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "check:spec": "node ../../packages/workspace-tools/src/index.js check module --path .",
    "test": "vitest run --root ../.. modules/document-extraction/src/document-extraction.test.ts modules/document-extraction/src/d1-document-extraction-store.test.ts modules/document-extraction/src/http.test.ts"
  },
  "dependencies": {
    "@microservices-sh/connection-contract": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "@microservices-sh/ui": "workspace:*",
    "svelte": "^5.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}

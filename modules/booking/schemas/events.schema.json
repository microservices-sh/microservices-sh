{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Booking Module Events",
  "type": "object",
  "properties": {
    "eventName": {
      "enum": ["booking.created", "booking.confirmed", "booking.cancelled"]
    },
    "entityType": {
      "const": "booking"
    },
    "entityId": { "type": "string" },
    "payload": { "type": "object" }
  },
  "required": ["eventName", "entityType", "entityId", "payload"]
}

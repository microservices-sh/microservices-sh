{
  "schemaVersion": "2026-06-13",
  "id": "org-team-rbac",
  "name": "Org, Team & RBAC",
  "version": "0.1.0",
  "status": "available",
  "class": "platform",
  "summary": "Multi-tenant organizations, memberships, roles, and invitations with a permission-resolution gate. Enforces tenant isolation and single-use, expiring invites — the B2B foundation other modules scope against.",
  "runtime": {
    "language": "typescript",
    "platform": "cloudflare-workers",
    "frameworkNeutral": true,
    "routeAdapters": ["sveltekit", "hono-later"]
  },
  "entrypoint": "src/index.ts",
  "resources": [
    { "type": "d1", "binding": "DB", "tables": ["organizations", "memberships", "roles", "invitations"] }
  ],
  "permissions": ["org.read", "org.manage", "member.manage", "org-team-rbac.extend", "org-team-rbac.observe"],
  "connections": {
    "requires": [],
    "optional": ["auth", "audit-log"],
    "rpc": {
      "exposes": [
        { "method": "authorize", "scope": "org.read", "public": false }
      ],
      "calls": []
    },
    "events": {
      "emits": ["org.created", "org.updated", "member.invited", "member.joined", "member.removed", "role.updated"],
      "consumes": []
    },
    "hookPoints": {
      "beforeInvite": { "kind": "filter", "scope": "org-team-rbac.extend" },
      "onMembershipChanged": { "kind": "observer", "scope": "org-team-rbac.observe" }
    },
    "provides": { "hooks": [] }
  },
  "customization": {
    "default": "config-hooks",
    "supported": ["config", "hooks", "overlay", "fork"]
  },
  "surfaces": {
    "admin": {
      "applicable": true,
      "nav": [{ "label": "Team", "path": "/team", "permission": "org.read", "icon": "UsersRound" }],
      "referenceUi": ["reference-ui/README.md"]
    },
    "visitor": {
      "applicable": true,
      "featureKey": "teamInvites",
      "referenceUi": ["reference-ui/README.md"]
    },
    "agentic": {
      "applicable": true,
      "tools": ["org-team-rbac.createOrganization", "org-team-rbac.updateOrganization", "org-team-rbac.listMembers", "org-team-rbac.inviteMember", "org-team-rbac.acceptInvitation", "org-team-rbac.updateMemberRole", "org-team-rbac.removeMember", "org-team-rbac.createRole", "org-team-rbac.authorize"],
      "skillPaths": ["skills/org-team-rbac-operator/SKILL.md"],
      "approvalRequiredFor": ["org-team-rbac.createOrganization", "org-team-rbac.updateOrganization", "org-team-rbac.inviteMember", "org-team-rbac.acceptInvitation", "org-team-rbac.updateMemberRole", "org-team-rbac.removeMember", "org-team-rbac.createRole"]
    }
  },
  "skills": [
    {
      "id": "org-team-rbac-operator",
      "path": "skills/org-team-rbac-operator/SKILL.md",
      "recommendedFor": ["admin-operations", "team-management", "permission-changes"]
    }
  ],
  "approval": {
    "risk": "high",
    "requiresApprovalFor": ["migrations", "permission-changes", "production-deploy"]
  }
}

{
  "name": "@microservices-sh/template-booking-sveltekit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Official microservices.sh Cloudflare SvelteKit booking app template shell.",
  "scripts": {
    "dev": "vite dev",
    "dev:local": "node scripts/microservices.js local dev",
    "build": "vite build",
    "build:app": "vite build",
    "preview": "vite preview",
    "check:spec": "node ../../packages/workspace-tools/src/index.js check template --path .",
    "db:migrate:local": "node scripts/microservices.js local migrate",
    "db:migrate:preview": "node scripts/microservices.js preview migrate --confirm migrate",
    "deploy:preview:dry-run": "node scripts/microservices.js preview deploy --dry-run",
    "deploy:preview": "node scripts/microservices.js preview deploy --confirm deploy",
    "smoke:http": "node scripts/microservices.js preview smoke",
    "smoke:local": "node scripts/microservices.js local smoke",
    "microservices": "node scripts/microservices.js"
  },
  "dependencies": {
    "@microservices-sh/booking": "workspace:*",
    "@microservices-sh/customer": "workspace:*",
    "@sveltejs/adapter-cloudflare": "^7.2.4",
    "@sveltejs/kit": "^2.9.0",
    "svelte": "^5.0.0",
    "vite": "^5.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "typescript": "^5.9.3",
    "wrangler": "^4.58.0"
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Video Generation Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "defaultProvider": {
      "type": "string",
      "default": "provider"
    },
    "maxPromptLength": {
      "type": "integer",
      "minimum": 1,
      "default": 4000
    },
    "defaultExpiryDays": {
      "type": "integer",
      "minimum": 0,
      "default": 7
    }
  }
}

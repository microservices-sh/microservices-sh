{
  "name": "@microservices-sh/accounting-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Tenant-scoped double-entry accounting foundation with chart of accounts, fiscal periods, balanced posting, voiding, trial balance, general ledger, and financial statements.",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./schemas": "./src/schemas.ts",
    "./hooks": "./src/hooks.ts",
    "./manifest": "./src/manifest/index.ts",
    "./config": "./src/config/index.ts",
    "./schema": "./src/schema/index.ts",
    "./events": "./src/events/index.ts",
    "./permissions": "./src/permissions/index.ts",
    "./resources": "./src/resources/index.ts",
    "./service": "./src/service/index.ts",
    "./ports": "./src/ports/index.ts",
    "./adapters/d1": "./src/adapters/d1-accounting-core-store.ts",
    "./adapters/memory": "./src/adapters/memory-accounting-core-store.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "check:spec": "node ../../packages/workspace-tools/src/index.js check module --path .",
    "test": "vitest run --root ../.. modules/accounting-core/src/accounting-core.test.ts"
  },
  "dependencies": {
    "@microservices-sh/connection-contract": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "@microservices-sh/test-utils": "workspace:*",
    "vitest": "^3.2.4",
    "typescript": "^5.9.3"
  }
}

{
  "schemaVersion": "2026-06-13",
  "id": "audit-log",
  "name": "Audit Log",
  "version": "0.1.0",
  "status": "available",
  "class": "sink",
  "summary": "Append-only audit trail. Pure event sink: records domain events from a signed queue or direct calls.",
  "runtime": {
    "language": "typescript",
    "platform": "cloudflare-workers",
    "frameworkNeutral": true,
    "routeAdapters": ["sveltekit", "hono-later"]
  },
  "entrypoint": "src/index.ts",
  "resources": [
    { "type": "d1", "binding": "DB", "tables": ["audit_events"] }
  ],
  "permissions": ["audit.read", "audit.export", "audit.admin", "audit.extend"],
  "connections": {
    "requires": [],
    "optional": ["auth", "customer", "booking", "payment"],
    "rpc": { "exposes": [], "calls": [] },
    "events": {
      "emits": ["audit.recorded", "audit.exported"],
      "consumes": [
        "auth.token_minted",
        "auth.key_rotated",
        "customer.created",
        "customer.updated",
        "booking.created",
        "booking.confirmed",
        "booking.cancelled",
        "payment.checkout_created",
        "payment.succeeded",
        "payment.refunded",
        "payment.failed"
      ]
    },
    "hookPoints": {
      "redactAuditPayload": { "kind": "filter", "scope": "audit.extend" },
      "beforeAuditExport": { "kind": "filter", "scope": "audit.extend" }
    },
    "provides": { "hooks": [] }
  },
  "customization": {
    "default": "config-hooks",
    "supported": ["config", "hooks", "overlay", "fork"]
  },
  "surfaces": {
    "admin": {
      "applicable": true,
      "nav": [{ "label": "Audit Log", "path": "/settings/audit-log", "permission": "audit.read", "icon": "FileSearch" }],
      "referenceUi": ["reference-ui/README.md"]
    },
    "visitor": {
      "applicable": false
    },
    "agentic": {
      "applicable": true,
      "tools": ["audit-log.listEvents", "audit-log.recordEvent", "audit-log.consumeEvent"],
      "skillPaths": ["skills/audit-log-operator/SKILL.md"],
      "approvalRequiredFor": ["audit-log.recordEvent", "audit-log.consumeEvent"]
    }
  },
  "skills": [
    {
      "id": "audit-log-operator",
      "path": "skills/audit-log-operator/SKILL.md",
      "recommendedFor": ["admin-operations", "compliance", "incident-review"]
    }
  ],
  "approval": {
    "risk": "medium",
    "requiresApprovalFor": ["migrations", "pii-redaction", "production-deploy"]
  }
}

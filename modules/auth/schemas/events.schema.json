{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Auth Events",
  "type": "object",
  "properties": {
    "eventName": {
      "type": "string",
      "enum": ["auth.token_minted", "auth.key_rotated"]
    },
    "entityType": {
      "type": "string",
      "const": "auth"
    }
  },
  "required": ["eventName", "entityType"]
}

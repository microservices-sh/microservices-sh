{
  "schemaVersion": "2026-06-13",
  "id": "jobs-workflows",
  "name": "Jobs & Workflows",
  "version": "0.1.0",
  "status": "available",
  "class": "platform",
  "summary": "Durable background jobs with idempotent execution, exponential-backoff retries, a dead-letter sink, and catch-up scheduling. The async backbone other modules build on.",
  "runtime": {
    "language": "typescript",
    "platform": "cloudflare-workers",
    "frameworkNeutral": true,
    "routeAdapters": ["sveltekit", "hono-later"]
  },
  "entrypoint": "src/index.ts",
  "resources": [
    { "type": "d1", "binding": "DB", "tables": ["jobs", "job_runs", "job_schedules"] },
    { "type": "queue", "binding": "JOBS_QUEUE", "optional": true }
  ],
  "permissions": ["jobs.enqueue", "jobs.read", "jobs.admin", "jobs-workflows.extend"],
  "connections": {
    "requires": [],
    "optional": ["audit-log"],
    "rpc": { "exposes": [], "calls": [] },
    "events": {
      "emits": ["job.enqueued", "job.succeeded", "job.retried", "job.dead", "job.scheduled"],
      "consumes": []
    },
    "hookPoints": {
      "beforeJobEnqueue": { "kind": "filter", "scope": "jobs-workflows.extend" },
      "computeBackoffMs": { "kind": "filter", "scope": "jobs-workflows.extend" },
      "onJobDead": { "kind": "observer", "scope": "jobs-workflows.extend" }
    },
    "provides": { "hooks": [] }
  },
  "customization": {
    "default": "config-hooks",
    "supported": ["config", "hooks", "overlay", "fork"]
  },
  "surfaces": {
    "admin": {
      "applicable": true,
      "nav": [{ "label": "Jobs", "path": "/settings/jobs", "permission": "jobs.read", "icon": "Workflow" }],
      "referenceUi": ["reference-ui/README.md"]
    },
    "visitor": {
      "applicable": false
    },
    "agentic": {
      "applicable": true,
      "tools": ["jobs-workflows.enqueueJob", "jobs-workflows.listJobs", "jobs-workflows.runJob", "jobs-workflows.runDueJobs", "jobs-workflows.upsertSchedule", "jobs-workflows.dueScheduledJobs"],
      "skillPaths": ["skills/jobs-workflows-operator/SKILL.md"],
      "approvalRequiredFor": ["jobs-workflows.enqueueJob", "jobs-workflows.runJob", "jobs-workflows.runDueJobs", "jobs-workflows.upsertSchedule"]
    }
  },
  "skills": [
    {
      "id": "jobs-workflows-operator",
      "path": "skills/jobs-workflows-operator/SKILL.md",
      "recommendedFor": ["admin-operations", "background-jobs", "workflow-triage"]
    }
  ],
  "approval": {
    "risk": "high",
    "requiresApprovalFor": ["migrations", "background-side-effects", "production-deploy"]
  }
}

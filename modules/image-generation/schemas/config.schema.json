{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Image Generation Module Config",
  "type": "object",
  "properties": {
    "defaultProvider": {
      "type": "string",
      "enum": ["kie-ai", "gemini", "gpt-image"],
      "default": "kie-ai"
    },
    "fallbackOrder": {
      "type": "array",
      "items": { "type": "string", "enum": ["kie-ai", "gemini", "gpt-image"] },
      "default": ["kie-ai", "gemini", "gpt-image"]
    },
    "allowedAspectRatios": {
      "type": "array",
      "items": { "type": "string", "enum": ["1:1", "3:4", "4:3", "9:16", "16:9"] },
      "default": ["1:1", "3:4", "4:3", "9:16", "16:9"]
    },
    "defaultListLimit": { "type": "integer", "minimum": 1, "maximum": 500, "default": 100 },
    "kieAiPollIntervalMs": { "type": "integer", "minimum": 1, "default": 2000 },
    "kieAiMaxPolls": { "type": "integer", "minimum": 1, "default": 45 }
  },
  "additionalProperties": false
}

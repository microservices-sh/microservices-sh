{
  "name": "microservices-sh",
  "private": true,
  "version": "0.0.0",
  "description": "microservices.sh monorepo \u2014 agent-native application infrastructure",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "cli": "pnpm --filter @microservices-sh/cli cli",
    "create:local": "pnpm --filter create-microservices-app start --",
    "test:create": "pnpm --filter create-microservices-app smoke",
    "spec:check": "node packages/workspace-tools/src/index.js check",
    "spec:check:all": "node packages/workspace-tools/src/index.js check all",
    "scaffold:module": "node packages/workspace-tools/src/index.js scaffold module",
    "scaffold:template": "node packages/workspace-tools/src/index.js scaffold template",
    "registry:build": "node packages/workspace-tools/src/index.js registry build",
    "sync:shims": "node packages/workspace-tools/src/index.js shims sync",
    "check:shims": "node packages/workspace-tools/src/index.js shims check",
    "discover": "node packages/workspace-tools/src/index.js discover",
    "mvp:modules": "pnpm --filter @microservices-sh/cli cli -- modules list --json",
    "mvp:generate": "pnpm --filter @microservices-sh/cli cli -- generate booking-business --out generated/examples/booking-business",
    "build": "pnpm -r build",
    "test": "vitest run"
  },
  "devDependencies": {
    "@microservices-sh/ads-manager": "workspace:*",
    "@microservices-sh/audit-log": "workspace:*",
    "@microservices-sh/auth": "workspace:*",
    "@microservices-sh/connection-contract": "workspace:*",
    "@microservices-sh/image-generation": "workspace:*",
    "@microservices-sh/payment": "workspace:*",
    "vitest": "^3.2.4"
  }
}

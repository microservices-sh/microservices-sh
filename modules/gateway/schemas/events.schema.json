{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Gateway Events",
  "type": "object",
  "properties": {
    "eventName": {
      "type": "string",
      "enum": ["gateway.token_issued", "gateway.access_denied"]
    },
    "entityType": {
      "type": "string",
      "const": "gateway"
    }
  },
  "required": ["eventName", "entityType"]
}
